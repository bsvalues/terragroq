{
  "version": 2,
  "control_rule": "WilliamOS dispatches only through explicit work-order execution grants. Catalog registration is not executable status, and no worker receives ambient write, commit, promotion, merge, or release authority.",
  "workers": [
    {
      "id": "claude-code",
      "label": "Claude Code",
      "kind": "external_code_worker",
      "mode": "hosted_provider_lane",
      "catalog_status": "registered",
      "execution_status": "provider_lane_unproven",
      "enabled": false,
      "availability": {
        "command": "claude",
        "args": ["--version"],
        "timeout_seconds": 8,
        "expected_contains": "Claude Code"
      },
      "allowed_tasks": [
        "code_review",
        "implementation_plan",
        "scoped_implementation",
        "patch_proposal",
        "test_failure_analysis",
        "validation",
        "commit",
        "push",
        "pull_request",
        "review_remediation"
      ],
      "delegation_policy": {
        "default": "work_order_grant_required",
        "authority": "work_order_bounded",
        "may_write": true,
        "may_commit": true,
        "may_promote": false
      },
      "execution_policy": {
        "requires_work_order_grant": true,
        "max_authority": "A8_PUSH",
        "allowed_actions": [
          "inspect",
          "proposal",
          "write",
          "test",
          "commit",
          "push",
          "open_pr",
          "merge",
          "review",
          "review_remediation"
        ],
        "blocked_actions": [
          "release",
          "deploy",
          "promote",
          "auth_or_secret_change",
          "destructive_change"
        ]
      },
      "preventive_trust_gate_v2": {
        "schemaVersion": 2,
        "workerIdentity": {
          "workerId": "claude-code",
          "provider": "anthropic",
          "surface": "claude-code-provider-lane",
          "attributable": true
        },
        "rawCredentialInspection": false,
        "promptInjectionBoundary": "trusted-work-order-envelope-v1",
        "exactPathConfinement": true,
        "outputRedaction": true,
        "cancellation": {
          "supported": true,
          "mode": "pre-dispatch"
        },
        "independentEvidenceCapture": true
      },
      "proposal_execution": {
        "enabled": false,
        "reason": "No durable authenticated Claude provider adapter is connected. Catalog registration does not make this lane executable."
      },
      "scope_policy": {
        "repo_required": true,
        "allowed_paths": [],
        "blocked_paths": [
          ".env",
          ".env.*",
          "secrets",
          "credentials",
          "*.key",
          "*.pem",
          "copilot.db"
        ]
      },
      "evidence_required": [
        "summary",
        "commands_run",
        "files_touched",
        "diff_or_patch",
        "test_results",
        "logs"
      ]
    },
