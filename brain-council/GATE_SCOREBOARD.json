{
  "version": "1.5.1",
  "gates": [
    {
      "gate": "artifact_created",
      "status": "PASS",
      "authority": "local"
    },
    {
      "gate": "install_to_william_os",
      "status": "PASS",
      "authority": "operator"
    },
    {
      "gate": "post_install_verify",
      "status": "PASS",
      "authority": "read_only"
    },
    {
      "gate": "codex_readonly_verify",
      "status": "OPTIONAL_NOT_RUN",
      "authority": "read_only_handoff"
