    {
      "gate": "commit_candidate_review",
      "status": "NOT_RUN",
      "authority": "owner_gate_required"
    },
    {
      "gate": "local_commit",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    },
    {
      "gate": "push",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    },
    {
      "gate": "pr_ready",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    },
    {
      "gate": "merge",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    },
    {
      "gate": "release",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    },
    {
      "gate": "mcp_activation",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    },
    {
      "gate": "autonomy",
      "status": "NOT_AUTHORIZED",
      "authority": "owner_required"
    }
  ]
}
